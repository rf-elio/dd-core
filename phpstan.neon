parameters:
    level: 5
    autoload_files:
        - %rootDir%/../../../vendor/autoload.php
        - %rootDir%/../../../../../../vendor/autoload.php
    autoload_directories:
    	- %rootDir%/../../../src
    excludes_analyse:
        - %rootDir%/../../../vendor/*
        - %rootDir%/../../../legacy-backup/*
    ignoreErrors:
    		-
    			message: '#expects string, null given#'
    			path: src/Api/ApiClientFactory.php