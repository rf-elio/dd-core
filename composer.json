{
    "name": "elio/fact-finder",
    "description": "",
    "version": "v2.0.0",
    "type": "shopware-platform-plugin",
    "authors": [
        {
            "name": "ry/elio GmbH"
        }
    ],
    "require": {
        "php": ">= 7.4",
        "ext-json": "*",
        "elio/fact-finder-api-client": "dev-master",
        "dragonmantank/cron-expression": "^3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^0.12.96"
    },
    "extra": {
        "shopware-plugin-class": "Elio\\FactFinder\\FactFinder",
        "label": {
            "de-DE": "ElioFactFinder",
            "en-GB": "ElioFactFinder"
        },
        "description": {
            "de-DE": "Deutsche Beschreibung des Plugins",
            "en-GB": "English description of the plugin"
        }
    },
    "autoload": {
        "psr-4": {
            "Elio\\FactFinder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elio\\FactFinder\\Tests\\": "tests/"
        }
    },
    "config": {
        "gitlab-domains": ["git.elio-systems.io"]
    },

    "repositories": {
        "git.elio-systems.io/201": {
            "type": "composer",
            "url": "https://git.elio-systems.io/api/v4/group/201/-/packages/composer/packages.json"
        }
    }
}
