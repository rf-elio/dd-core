<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- api -->
        <service id="Elio\FactFinder\Api\ApiClientFactory">
            <argument type="service" id="Elio\FactFinder\Configuration\FactFinderConfigService"/>
            <argument>%kernel.logs_dir%</argument>
        </service>

        <service id="Elio\FactFinder\Api\Campaign\CampaignApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
        </service>
        <service id="Elio\FactFinder\Api\Import\ImportApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
            <argument type="service" id="Elio\FactFinder\Api\Transform\Transformer"/>
        </service>
        <service id="Elio\FactFinder\Api\Management\ManagementApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
        </service>
        <service id="Elio\FactFinder\Api\PredictiveBasket\PredictiveBasketApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
        </service>
        <service id="Elio\FactFinder\Api\Records\RecordsApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
            <argument type="service" id="Elio\FactFinder\Api\Transform\Transformer"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\SearchApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
            <argument type="service" id="Elio\FactFinder\Api\Transform\Transformer"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\SuggestApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
            <argument type="service" id="Elio\FactFinder\Api\Transform\Transformer"/>
        </service>
        <service id="Elio\FactFinder\Api\Tracking\TrackingApi">
            <argument type="service" id="Elio\FactFinder\Api\ApiClientFactory"/>
            <argument type="service" id="Elio\FactFinder\Logger" />
        </service>

        <!-- transformer -->
        <service id="Elio\FactFinder\Api\Transform\Transformer">
            <argument type="tagged" tag="elio-ff.api.transformer.response"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Elio\FactFinder\Logger"/>
        </service>

        <!-- transformer / response / search -->
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\TimeoutTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\PagingTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\TotalHitsTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\SortTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\TranslationSortTransformer"
                 decorates="Elio\FactFinder\Api\Search\ResponseTransformer\SortTransformer">
            <argument type="service" id="product_sorting.repository" />
            <argument type="service" id="Elio\FactFinder\Api\Search\ResponseTransformer\TranslationSortTransformer.inner" />
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\ProductTransformer">
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingLoader" />
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\FacetTransformer">
            <argument type="service" id="Elio\FactFinder\Core\FilterRestrictions\FilterService" />
            <argument type="service" id="Shopware\Core\Content\Category\Service\NavigationLoader"/>
            <argument type="service" id="category.repository" />
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\SuggestionTransformer">
            <argument type="service" id="Elio\FactFinder\Configuration\FactFinderConfigService" />
            <argument type="service" id="event_dispatcher"/>
            <tag name="elio-ff.api.transformer.response" priority="50"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\SuggestionProductTransformer">
            <argument type="service" id="product.repository" />
            <tag name="elio-ff.api.transformer.response" priority="49"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\SuggestionCategoryTransformer">
            <argument type="service" id="category.repository" />
            <tag name="elio-ff.api.transformer.response" priority="49"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\CampaignTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>
        <service id="Elio\FactFinder\Api\Search\ResponseTransformer\ContentTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>

        <!-- transformer / response / import -->
        <service id="Elio\FactFinder\Api\Import\ResponseTransformer\ImportTransformer">
            <tag name="elio-ff.api.transformer.response"/>
        </service>

        <!-- transformer / response / records -->
        <service id="Elio\FactFinder\Api\Records\ResponseTransformer\ProductTransformer">
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingLoader" />
            <tag name="elio-ff.api.transformer.response"/>
        </service>

        <!-- commands -->
        <service id="Elio\FactFinder\Command\RecordsGetCommand">
            <argument id="Elio\FactFinder\Api\Records\RecordsApi" type="service"/>
            <argument id="Elio\FactFinder\Configuration\FactFinderConfigService" type="service"/>
            <argument id="sales_channel.repository" type="service"/>
            <tag name="console.command"/>
        </service>
    </services>
</container>
