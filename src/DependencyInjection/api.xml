<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- api -->
        <service id="Elio\ElioDataDiscovery\Api\Search\SearchApi">
            <argument type="service" id="elio.data-discovery.core.logging.debug"/>
        </service>
        <service id="Elio\ElioDataDiscovery\Api\Search\CachedSearchApi"
                 decorates="Elio\ElioDataDiscovery\Api\Search\SearchApi" decoration-priority="-5000">
            <argument type="service" id="Symfony\Contracts\Cache\CacheInterface"/>
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\CachedSearchApi.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
        </service>
        <service id="Elio\ElioDataDiscovery\Api\Search\ProductRedirectSearchApi"
                 decorates="Elio\ElioDataDiscovery\Api\Search\SearchApi" decoration-priority="-4000">
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\ProductRedirectSearchApi.inner" />
            <argument type="service" id="Shopware\Core\Content\Seo\SeoUrlPlaceholderHandlerInterface" />
            <argument type="service" id="router" />
            <argument type="service" id="elio.data-discovery.core.logging.request"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\ProductCloseoutFilterFactory"/>
            <argument type="service" id="sales_channel_domain.repository"/>
        </service>
        <service id="Elio\ElioDataDiscovery\Api\Search\SuggestApi"/>
        <service id="Elio\ElioDataDiscovery\Api\Tracking\TrackingApi">
            <argument type="service" id="elio.data-discovery.core.logging.debug" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Logging\RequestLoggingService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
        </service>

        <service id="Elio\ElioDataDiscovery\Api\Recommendations\RecommendationApi">
            <argument type="service" id="elio.data-discovery.core.logging.debug" />
        </service>

        <service id="Elio\ElioDataDiscovery\Api\Configuration\ConfigurationAdapter">
            <argument type="service" id="elio.data-discovery.core.logging.debug" />
        </service>

        <!-- transformer -->
        <service id="Elio\ElioDataDiscovery\Api\Transform\Transformer">
            <argument type="tagged" tag="elio-data-discovery.api.transformer.response"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="elio.data-discovery.core.logging.default"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Api\Transform\RecommendationProductTransformer">
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingLoader" />
            <tag name="elio-data-discovery.api.transformer.response"/>
        </service>
    </services>
</container>
