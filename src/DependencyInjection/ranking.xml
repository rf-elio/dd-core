<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
       <!-- command -->
        <service id="Elio\ElioDataDiscovery\Command\RankingUpdateCommand">
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Ranking\ProductRankingUpdateService" />
            <tag name="console.command"/>
        </service>

        <!-- scheduled task -->
        <service id="Elio\ElioDataDiscovery\Core\Ranking\ScheduledTask\ProductRankingUpdateScheduledTask">
            <tag name="shopware.scheduled.task"/>
        </service>
        <service id="Elio\ElioDataDiscovery\Core\Ranking\ScheduledTask\ProductRankingUpdateScheduledTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Ranking\ProductRankingUpdateService" />
            <tag name="messenger.message_handler"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Ranking\Api\RankingAdminController" public="true">
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Ranking\ProductRankingUpdateService" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!-- service -->
        <service id="Elio\ElioDataDiscovery\Core\Ranking\ProductRankingUpdateService">
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="sales_channel.repository" />
            <argument type="service" id="Doctrine\DBAL\Connection" />
        </service>
    </services>
</container>
