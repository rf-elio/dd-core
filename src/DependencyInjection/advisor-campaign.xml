<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioDataDiscovery\Core\AdvisorCampaign\SalesChannel\AdvisorCampaignRoute" public="true">
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\SearchApi" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductSearchRequestBuilder" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductListingResultTransformer" />
        </service>

        <service id="Elio\ElioDataDiscovery\Core\AdvisorCampaign\Subscriber\AdvisorSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
