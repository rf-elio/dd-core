<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>

        <service id="Elio\ElioSearch\Core\FilterRestrictions\FilterDefinition">
            <tag name="shopware.entity.definition" entity="elio_search_filter"/>
        </service>

        <service id="Elio\ElioSearch\Core\FilterRestrictions\FilterRestrictionsDefinition">
            <tag name="shopware.entity.definition" entity="elio_search_filter_restrictions"/>
        </service>

        <service id="Elio\ElioSearch\Core\FilterRestrictions\FilterRestrictionsFilterMapping">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="Elio\ElioSearch\Core\FilterRestrictions\Aggregate\FilterDefinitionTranslation\FilterDefinitionTranslationDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="Elio\ElioSearch\Core\FilterRestrictions\FilterService">
            <argument type="service" id="elio_search_filter_restrictions.repository" />
            <argument type="service" id="category.repository" />
            <argument type="service" id="Elio\ElioSearch\Configuration\ElioSearchConfigService"/>
        </service>
        <service id="Elio\ElioSearch\Core\FilterRestrictions\FilterSyncService">
            <argument type="service" id="property_group.repository" />
            <argument type="service" id="elio_search_filter.repository" />
            <argument type="service" id="elio_search_filter_translation.repository" />
            <argument type="service" id="logger" />
        </service>
        <service id="Elio\ElioSearch\Core\FilterRestrictions\CachedFilterService"
                 decorates="Elio\ElioSearch\Core\FilterRestrictions\FilterService">
            <argument type="service" id="Elio\ElioSearch\Core\FilterRestrictions\CachedFilterService.inner" />
            <argument type="service" id="cache.object"/>
            <argument type="service" id="Elio\ElioSearch\Configuration\ElioSearchConfigService"/>
        </service>

        <service id="Elio\ElioSearch\Storefront\Subscriber\FilterRestrictionsSubscriber">
            <argument type="service" id="Elio\ElioSearch\Core\FilterRestrictions\CachedFilterService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Elio\ElioSearch\Command\SynchronizePropertiesToFiltersCommand">
            <argument type="service" id="Elio\ElioSearch\Core\FilterRestrictions\FilterSyncService" />
            <tag name="console.command"/>
        </service>

    </services>
</container>
