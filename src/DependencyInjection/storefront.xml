<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioDataDiscovery\Storefront\Framework\Cookie\ElioDataDiscoveryCookieProvider"
                 decorates="Shopware\Storefront\Framework\Cookie\CookieProviderInterface"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Storefront\Framework\Cookie\ElioDataDiscoveryCookieProvider.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument id="request_stack" type="service"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Storefront\Controller\SuggestController"
                 decorates="Shopware\Storefront\Controller\SearchController"
                 public="true"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\SuggestApi" />
            <argument type="service" id="Shopware\Storefront\Page\Search\SearchPageLoader"/>
            <argument type="service" id="Shopware\Storefront\Page\Suggest\SuggestPageLoader"/>
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Search\ProductSearchRoute"/>
            <argument type="service" id="elio.data-discovery.core.logging.default"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
        </service>

        <service id="Elio\ElioDataDiscovery\Storefront\Subscriber\CampaignRedirectionSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Storefront\Controller\ProductDetailCrossSellingController" public="true">
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\CrossSelling\ProductCrossSellingRoute" />
            <argument type="service" id="elio.data-discovery.core.logging.default" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
        </service>

        <service id="Elio\ElioDataDiscovery\Storefront\Controller\AdvisorCampaignController" public="true">
            <argument type="service" id="Elio\ElioDataDiscovery\Core\AdvisorCampaign\SalesChannel\AdvisorCampaignRoute" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
            <call method="setTwig">
                <argument type="service" id="twig"/>
            </call>
        </service>
    </services>
</container>
