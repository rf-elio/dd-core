<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioDataDiscovery\Core\Features\Api\FeaturesController" public="true">
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Features\FeatureService" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
        <service id="Elio\ElioDataDiscovery\Core\Features\FeatureService">
            <argument type="service" id="event_dispatcher"/>
        </service>
    </services>
</container>