<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\FactFinder\Core\Search\SearchRequestBuilder">
            <argument type="service" id="Elio\FactFinder\Configuration\FactFinderConfigService" />
        </service>

        <service id="Elio\FactFinder\Core\Search\FactFinderSearchRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Search\ProductSearchRoute">
            <argument type="service" id="Elio\FactFinder\Core\Search\FactFinderSearchRoute.inner" />
            <argument type="service" id="Elio\FactFinder\Core\Search\SearchRequestBuilder" />
            <argument type="service" id="Elio\FactFinder\Configuration\FactFinderConfigService" />
            <argument type="service" id="Elio\FactFinder\Api\Search\SearchApi" />
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingLoader" />
            <argument type="service" id="event_dispatcher" />
        </service>
    </services>
</container>