<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Features\FeatureService" />
        </service>
        <service id="Elio\ElioDataDiscovery\Storefront\TwigExtension\ConfigLanguageBased">
            <argument type="service" id="Shopware\Storefront\Framework\Twig\TemplateConfigAccessor"/>
            <argument type="service" id="language.repository"/>
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService"/>
            <argument type="service" id="cache.object"/>
            <tag name="twig.extension"/>
        </service>
    </services>
</container>