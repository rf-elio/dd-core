<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\FactFinder\Core\BotProtection\BotDetectionService">
            <argument type="service" id="Elio\FactFinder\Configuration\FactFinderConfigService" />
            <argument type="service" id="event_dispatcher" />
        </service>
        <service id="Elio\FactFinder\Core\BotProtection\BotProtectionRequestSubscriber">
            <argument type="service" id="Elio\FactFinder\Core\BotProtection\BotDetectionService" />
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>