<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductListingResultTransformer">
            <argument type="service" id="event_dispatcher"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductSearchRequestBuilder">
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="event_dispatcher"/>
        </service>
        <service id="Elio\ElioDataDiscovery\Core\Content\Content\SalesChannel\ContentSearchRequestBuilder">
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Search\ElioDataDiscoveryRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Search\ProductSearchRoute"
                 decoration-priority="-3000"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Search\ElioDataDiscoveryRoute.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductSearchRequestBuilder" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Content\SalesChannel\ContentSearchRequestBuilder" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\SearchApi" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductListingResultTransformer" />
            <argument type="service" id="elio.data-discovery.core.logging.default" />
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Detail\ElioDataDiscoveryProductDetailRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Detail\ProductDetailRoute"
                 decoration-priority="-3000"
                 public="true"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Detail\ElioDataDiscoveryProductDetailRoute.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Recommendations\RecommendationApi" />
            <argument type="service" id="elio.data-discovery.core.logging.debug" />
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\CrossSelling\ElioDataDiscoveryProductCrossSellingRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\CrossSelling\ProductCrossSellingRoute"
                 decoration-priority="-3000"
                 public="true"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\CrossSelling\ElioDataDiscoveryProductCrossSellingRoute.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="translator"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Recommendations\RecommendationApi"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Listing\ElioDataDiscoveryProductListingRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingRoute"
                 decoration-priority="-3000"
                 public="true"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Listing\ElioDataDiscoveryProductListingRoute.inner" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductSearchRequestBuilder" />
            <argument type="service" id="Elio\ElioDataDiscovery\Configuration\ElioDataDiscoveryConfigService" />
            <argument type="service" id="Elio\ElioDataDiscovery\Api\Search\SearchApi" />
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\ProductListingResultTransformer" />
            <argument type="service" id="category.repository"/>
            <argument type="service" id="Shopware\Core\Content\Category\Service\CategoryBreadcrumbBuilder"/>
            <argument type="service" id="elio.data-discovery.core.logging.default" />
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\Subscriber\ProductSubscriber">
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Sync\RatingCountService"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Listing\ProductListingLoaderDecorator"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Listing\ProductListingLoader"
                 decoration-priority="-3000"
                 public="true"
        >
            <argument type="service" id="Elio\ElioDataDiscovery\Core\Content\Product\SalesChannel\Listing\ProductListingLoaderDecorator.inner"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Shopware\Core\Content\Product\SalesChannel\ProductCloseoutFilterFactory"/>
        </service>
    </services>
</container>
