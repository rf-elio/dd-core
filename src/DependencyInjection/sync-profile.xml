<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\ElioSearch\Core\Sync\SyncProfileDefinition">
            <tag name="shopware.entity.definition" entity="elio_search_sync_profile"/>
        </service>

        <service id="Elio\ElioSearch\Core\Sync\SyncProfileLanguageMapping">
            <tag name="shopware.entity.definition" entity="elio_search_sync_profile_languages"/>
        </service>

        <service id="Elio\ElioSearch\Core\Sync\Aggregate\LanguageExtension">
            <tag name="shopware.entity.extension"/>
        </service>

        <service id="Elio\ElioSearch\Core\Sync\ChangeSet\EntityStatusDefinition">
            <tag name="shopware.entity.definition" entity="elio_search_entity_status"/>
        </service>

        <!--   Sync    -->
        <!--   Collector    -->
        <service id="Elio\ElioSearch\Core\Sync\Collector\ProductCollector">
            <argument type="service" id="sales_channel.product.repository" />
            <argument type="service" id="sales_channel.category.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Elio\ElioSearch\Configuration\ElioSearchConfigService"/>
            <tag name="elio-search.sync.collector"/>
        </service>
        <service id="Elio\ElioSearch\Core\Sync\Collector\CategoryCollector">
            <argument type="service" id="sales_channel.category.repository" />
            <argument type="service" id="event_dispatcher" />
            <tag name="elio-search.sync.collector"/>
        </service>
        <service id="Elio\ElioSearch\Core\Sync\Collector\LandingPageCollector">
            <argument type="service" id="sales_channel.landing_page.repository" />
            <argument type="service" id="event_dispatcher" />
            <tag name="elio-search.sync.collector"/>
        </service>

        <!--    Api Sync    -->
        <service id="Elio\ElioSearch\Core\Sync\ChangeSet\Indexer\ProductIndexer">
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <tag name="elio-search.sync.indexer"/>
        </service>
        <service id="Elio\ElioSearch\Core\Sync\ChangeSet\Indexer\CategoryIndexer">
            <argument type="service" id="category.repository" />
            <argument type="service" id="event_dispatcher" />
            <tag name="elio-search.sync.indexer"/>
        </service>
        <service id="Elio\ElioSearch\Core\Sync\ChangeSet\Indexer\LandingPageIndexer">
            <argument type="service" id="landing_page.repository" />
            <argument type="service" id="event_dispatcher" />
            <tag name="elio-search.sync.indexer"/>
        </service>
        <service id="Elio\ElioSearch\Core\Sync\ChangeSet\ChangeSetService">
            <argument type="service" id="elio_search_entity_status.repository" />
            <argument type="tagged" tag="elio-search.sync.indexer" />
            <argument type="service" id="elio.search.core.logging.default" />
        </service>
<!--        <service id="Elio\ElioSearch\Core\Sync\Output\Api\ApiService">-->
<!--            <argument type="service" id="Elio\ElioSearch\Core\Sync\ChangeSet\ChangeSetService" />-->
<!--            <argument type="tagged" tag="elio-search.sync.collector" />-->
<!--            <argument type="service" id="event_dispatcher" />-->
<!--            <argument type="service" id="elio.search.core.logging.default" />-->
<!--        </service>-->

        <!-- outputs -->
        <service id="Elio\ElioSearch\Core\Sync\Output\OutputService">
            <argument type="tagged" tag="elio-search.sync.api.output" />
        </service>
        <service id="Elio\ElioSearch\Core\Sync\Output\SeoRouteOutput">
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="router"/>
            <argument type="service" id="elio.search.core.logging.default"/>
            <tag name="elio-search.sync.api.output"/>
        </service>

        <!-- inputs -->
        <service id="Elio\ElioSearch\Core\Sync\Input\InputService">
            <argument type="tagged" tag="elio-search.sync.api.input" />
        </service>

        <service id="Elio\ElioSearch\Core\Sync\Input\DeltaInput">
            <argument type="service" id="Elio\ElioSearch\Core\Sync\ChangeSet\ChangeSetService" />
            <argument type="tagged" tag="elio-search.sync.collector" />
            <argument type="service" id="elio.search.core.logging.default" />
            <tag name="elio-search.sync.api.input" />
        </service>

        <service id="Elio\ElioSearch\Core\Sync\SyncService">
            <argument type="service" id="elio_search_sync_profile.repository" />
            <argument type="tagged" tag="elio-search.sync.profile" />
            <argument type="service" id="Elio\ElioSearch\Core\Sync\Input\InputService" />
            <argument type="service" id="Elio\ElioSearch\Core\Sync\Output\OutputService" />
            <argument type="service" id="Shopware\Core\System\SalesChannel\Context\SalesChannelContextFactory" />
            <argument type="service" id="elio.search.core.logging.default" />
        </service>

        <service id="Elio\ElioSearch\Core\Sync\Api\SyncProfileController" public="true">
            <argument type="tagged" tag="elio-search.sync.profile" />
            <argument type="service" id="Elio\ElioSearch\Core\Sync\SyncService" />
            <argument type="service" id="Symfony\Component\Messenger\MessageBusInterface" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Elio\ElioSearch\Command\SyncDataCommand">
            <argument type="service" id="Elio\ElioSearch\Core\Sync\SyncService" />
            <argument type="service" id="elio.search.core.logging.default" />
            <tag name="console.command"/>
        </service>
        <service id="Elio\ElioSearch\Command\IndexUpdateCommand">
            <argument type="service" id="Elio\ElioSearch\Core\Sync\ChangeSet\ChangeSetService" />
            <argument type="service" id="elio.search.core.logging.default" />
            <tag name="console.command"/>
        </service>
        <service id="Elio\ElioSearch\Command\IndexCleanupCommand">
            <argument type="service" id="Elio\ElioSearch\Core\Sync\SyncService" />
            <argument type="service" id="Elio\ElioSearch\Core\Sync\ChangeSet\ChangeSetService" />
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
            <argument type="service" id="elio.search.core.logging.default" />
            <tag name="console.command"/>
        </service>

        <!-- message handler -->
        <service id="Elio\ElioSearch\Core\Sync\SyncProfileHandler">
            <argument type="service" id="Elio\ElioSearch\Core\Sync\SyncService" />
            <tag name="messenger.message_handler" />
        </service>
    </services>
</container>
