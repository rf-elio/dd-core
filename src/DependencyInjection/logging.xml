<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- core -->
        <service id="Elio\ElioSearch\Core\Logging\LoggingService">
            <argument>%kernel.logs_dir%</argument>
        </service>
        <service id="Elio\ElioSearch\Core\Logging\LogFilterContext"/>

        <!-- api -->
        <service id="Elio\ElioSearch\Core\Logging\Api\Controller\LoggingController" public="true">
            <argument type="service" id="Elio\ElioSearch\Core\Logging\LoggingService" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!-- subscriber -->
        <service id="Elio\ElioSearch\Core\Logging\Subscriber\LogIpFilterSubscriber">
            <argument type="service" id="Elio\ElioSearch\Configuration\ElioSearchConfigService"/>
            <argument type="service" id="Elio\ElioSearch\Core\Logging\LogFilterContext"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- logger -->
        <service id="Elio\ElioSearch\Core\Logging\LoggerFactory">
            <argument type="string">%kernel.logs_dir%/%%s_%kernel.environment%.log</argument>
            <argument>%shopware.logger.file_rotation_count%</argument>
            <argument type="service" id="Elio\ElioSearch\Core\Logging\LogFilterContext" />
        </service>
        <service id="elio.search.core.logging.default" class="Monolog\Logger">
            <factory service="Elio\ElioSearch\Core\Logging\LoggerFactory" method="createRotating" />
            <argument type="string">elio_search_default</argument>
            <argument type="string">10</argument>
            <argument type="string">false</argument>
        </service>
        <service id="elio.search.core.logging.debug" class="Monolog\Logger">
            <factory service="Elio\ElioSearch\Core\Logging\LoggerFactory" method="createRotating" />
            <argument type="string">elio_search_debug</argument>
            <argument type="string">10</argument>
            <argument type="string">true</argument>
        </service>
    </services>
</container>
