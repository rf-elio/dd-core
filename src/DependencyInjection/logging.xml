<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- api -->
        <service id="Elio\FactFinder\Core\Logging\Controller\LoggingController" public="true">
            <argument type="service" id="Elio\FactFinder\Core\Logging\LoggingService" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Elio\FactFinder\Core\Logging\LoggingService">
            <argument>%kernel.logs_dir%</argument>
        </service>


    </services>
</container>
