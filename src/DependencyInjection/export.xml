<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Elio\FactFinder\Core\Export\ExportDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="Elio\FactFinder\Command\ExportGenerateCommand">
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportService" />
            <tag name="console.command"/>
        </service>

        <service id="Elio\FactFinder\Core\Export\ExportService">
            <argument type="service" id="elio_ff_export.repository" />
            <argument type="service" id="Shopware\Core\System\SalesChannel\Context\SalesChannelContextFactory" />
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="logger" />
            <argument type="tagged" tag="elio-ff.export.generator" />
            <argument type="tagged" tag="elio-ff.export.writer" />
        </service>

        <!-- generators / product -->
        <service id="Elio\FactFinder\Core\Export\Generator\Product\ProductExportGenerator">
            <argument type="service" id="product.repository" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="sales_channel.repository" />
            <argument type="service" id="Elio\FactFinder\Core\Features\FeatureService" />
            <tag name="elio-ff.export.generator" />
        </service>
        <!-- generators / content -->
        <service id="Elio\FactFinder\Core\Export\Generator\Content\CategoryExportGenerator">
            <argument type="service" id="category.repository" />
            <argument type="service" id="router"/>
            <tag name="elio-ff.export.generator" />
        </service>
        <service id="Elio\FactFinder\Core\Export\Generator\Content\LandingPagePartialGenerator">
            <argument type="service" id="landing_page.repository" />
            <tag name="elio-ff.export.generator" />
        </service>

        <!-- storage -->
        <service id="Elio\FactFinder\Core\Export\ExportStorageService">
            <argument type="service" id="shopware.filesystem.private" />
        </service>

        <!-- writers -->
        <service id="Elio\FactFinder\Core\Export\Writer\CSVFileWriter">
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportStorageService" />
            <tag name="elio-ff.export.writer"/>
        </service>
        <service id="elio.fact_finder.core.export.writer.seo_url_writer.csv"
                 class="Elio\FactFinder\Core\Export\Writer\SeoUrlWriter"
                 decorates="Elio\FactFinder\Core\Export\Writer\CSVFileWriter">
            <argument type="service" id="elio.fact_finder.core.export.writer.seo_url_writer.csv.inner" />
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="router"/>
        </service>
        <service id="Elio\FactFinder\Core\Export\Writer\XMLFileWriter">
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportStorageService" />
            <tag name="elio-ff.export.writer"/>
        </service>

        <!-- controller -->
        <service id="Elio\FactFinder\Core\Export\Controller\ExportController" public="true">
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportStorageService" />
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportService" />
            <argument type="service" id="Symfony\Component\Messenger\MessageBusInterface" />
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!-- message handler -->
        <service id="Elio\FactFinder\Core\Export\ExportGenerateHandler">
            <argument type="service" id="Elio\FactFinder\Core\Export\ExportService" />
            <tag name="messenger.message_handler" />
        </service>
    </services>
</container>
