module.exports = "<div class=\"elio-language-selector\">\n    <div class=\"elio-language-selector__inner\"\n         ref=\"elioLanguageSelector\">\n        <button class=\"elio-language-selector__header\"\n                type=\"button\"\n                @click.prevent=\"openSelector\">\n            <span>All</span>\n        </button>\n        <div class=\"elio-language-selector__drop\">\n            <ul class=\"elio-language-selector__list elio-language-selector-scroll\">\n                <li v-for=\"language in languages\"\n                    :class=\"['elio-language-selector__list-item', {'elio-language-selector__list-item--active': language.active}]\"\n                    @click.prevent=\"pickSelector\">\n                    <label class=\"elio-language-selector-check\">\n                        <span class=\"elio-language-selector-check__descr\"\n                              :data-selector-value=\"language.id\">\n                            {{ language.value }}\n                        </span>\n                    </label>\n                </li>\n            </ul>\n        </div>\n    </div>\n</div>";