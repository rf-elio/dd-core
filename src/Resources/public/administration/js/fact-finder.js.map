module.exports = "{% block ff_restrictions_category_page %}\n    <div class=\"sw-category-detail-base\">\n        <div class=\"elio-ff-restrictions-sales-channel-picker elio-ff-restrictions-sales-channel-picker--category\">\n            <sw-sales-channel-switch :label=\"$tc('sw-settings.system-config.labelSalesChannelSelect')\"\n                                     @change-sales-channel-id=\"onSalesChannelChanged\">\n            </sw-sales-channel-switch>\n        </div>\n\n        <sw-card :title=\"$tc('ff.restrictions.tabs.global')\"\n                 :isLoading=\"isLoading\">\n            <ff-restriction-ruler :isCategory=\"true\"\n                                  :categoryId=\"category.id\"\n                                  ref=\"ruler\"></ff-restriction-ruler>\n        </sw-card>\n    </div>\n{% endblock %}";