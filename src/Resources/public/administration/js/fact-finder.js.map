module.exports = "{% block ff_restrictions_index_page %}\n    <sw-meteor-page class=\"ff-restrictions-index\" hideIcon>\n\n        {% block ff_restrictions_index_page_smart_bar_tabs %}\n            <template slot=\"page-tabs\">\n                {% block ff_restrictions_index_page_smart_bar_tabs_global %}\n                    <sw-tabs-item :route=\"{ name: 'elio.factfinder.restrictions.index.global' }\">\n                        {{ $tc('ff.restrictions.tabs.global') }}\n                    </sw-tabs-item>\n                {% endblock %}\n\n                {% block ff_restrictions_index_page_smart_bar_tabs_search %}\n                    <sw-tabs-item :route=\"{ name: 'elio.factfinder.restrictions.index.search' }\">\n                        {{ $tc('ff.restrictions.tabs.search') }}\n                    </sw-tabs-item>\n                {% endblock %}\n\n                {% block ff_restrictions_index_page_smart_bar_tabs_navigation %}\n                    <sw-tabs-item :route=\"{ name: 'elio.factfinder.restrictions.index.navigation' }\">\n                        {{ $tc('ff.restrictions.tabs.navigation') }}\n                    </sw-tabs-item>\n                {% endblock %}\n\n                {% block ff_restrictions_index_page_smart_bar_tabs_customfilters %}\n                    <sw-tabs-item :route=\"{ name: 'elio.factfinder.restrictions.index.customfilters' }\">\n                        {{ $tc('ff.restrictions.tabs.customfilters') }}\n                    </sw-tabs-item>\n                {% endblock %}\n            </template>\n        {% endblock %}\n\n        {% block ff_restrictions_index_page_smart_bar_actions %}\n            <template slot=\"smart-bar-actions\">\n                <sw-button-process v-if=\"!isCustomFiltersTab\"\n                                   class=\"sw-category-detail__save-action\"\n                                   :isLoading=\"isLoading\"\n                                   :processSuccess=\"isSaveSuccessful\"\n                                   :disabled=\"isLoading\"\n                                   variant=\"primary\"\n                                   @process-finish=\"saveFinish\"\n                                   @click.prevent=\"onSave\">\n                    {{ $tc('sw-category.general.buttonSafeCategory') }}\n                </sw-button-process>\n                <sw-button v-if=\"isCustomFiltersTab\"\n                           class=\"sw-property-list__button-create\"\n                           :routerLink=\"{ name: 'elio.factfinder.restrictions.customFiltersCreate' }\"\n                           variant=\"primary\">\n                    {{ $tc('sw-property.list.buttonAddProperty') }}\n                </sw-button>\n            </template>\n        {% endblock %}\n\n        {% block ff_restrictions_index_page_body %}\n            <template slot=\"default\">\n                <router-view ref=\"routerView\"></router-view>\n            </template>\n        {% endblock %}\n\n    </sw-meteor-page>\n{% endblock %}";