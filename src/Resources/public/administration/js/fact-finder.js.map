module.exports = "{% block ff_export_detail %}\n    <sw-page class=\"sw-property-detail\">\n\n        {% block ff_export_detail_smart_bar_header %}\n            <template slot=\"smart-bar-header\">\n                {% block ff_export_detail_smart_bar_header_title %}\n                    <h2>{{ placeholder(ff_export, 'name', $tc('ff-export.detail.textHeadline')) }}</h2>\n                {% endblock %}\n            </template>\n        {% endblock %}\n\n        {% block ff_export_detail_smart_bar_actions %}\n            <template slot=\"smart-bar-actions\">\n                {% block ff_export_detail_smart_bar_actions_cancel %}\n                    <sw-button class=\"sw-property-detail__back-action\"\n                               :disabled=\"isLoading\"\n                               @click=\"onCancel\">\n                        {{ $tc('ff-export.buttonCancel') }}\n                    </sw-button>\n                {% endblock %}\n\n                {% block ff_export_detail_smart_bar_actions_save %}\n                    <sw-button-process\n                            class=\"sw-property-detail__save-action\"\n                            :isLoading=\"isLoading\"\n                            :processSuccess=\"isSaveSuccessful\"\n                            :disabled=\"isLoading\"\n                            variant=\"primary\"\n                            @process-finish=\"onSaveFinish\"\n                            @click.prevent=\"onSave\">\n                        {{ $tc('ff-export.buttonSave') }}\n                    </sw-button-process>\n                {% endblock %}\n            </template>\n        {% endblock %}\n\n        {% block ff_export_detail_content %}\n            <sw-card-view slot=\"content\">\n\n                {% block ff_export_detail_content_language_info %}\n                    <sw-language-info\n                            :entityDescription=\"placeholder(ff_export, 'name', $tc('ff-export.detail.textHeadline'))\">\n                    </sw-language-info>\n                {% endblock %}\n\n                <sw-card v-if=\"ff_export\" :title=\"$tc('ff-export.detail.cardTitleBasicInfo')\" :isLoading=\"isLoading\">\n                    <sw-container slot=\"grid\" rows=\"auto auto\">\n                        <sw-card-section divider=\"bottom\">\n                            {% block ff_export_detail_basic_info %}\n                                <sw-field\n                                        v-model=\"ff_export.name\"\n                                        type=\"text\"\n                                        required\n                                        :label=\"$tc('ff-export.detail.labelName')\"\n                                        :placeholder=\"placeholder(ff_export, 'name', $tc('ff-export.detail.placeholderName'))\">\n                                </sw-field>\n                                <div class=\"sw-container\" style=\"grid-template-columns: 1fr 1fr 1fr; gap: 0px 30px; place-items: stretch;\">\n                                    <sw-field\n                                            v-model=\"ff_export.type\"\n                                            type=\"select\"\n                                            required\n                                            :options=\"typeList\"\n                                            :label=\"$tc('ff-export.detail.labelType')\">\n                                    </sw-field>\n\n                                    <sw-field\n                                            v-model=\"ff_export.format\"\n                                            type=\"select\"\n                                            required\n                                            :options=\"formatList\"\n                                            :label=\"$tc('ff-export.detail.labelFormat')\">\n                                    </sw-field>\n\n                                    <sw-field\n                                            v-model=\"ff_export.active\"\n                                            type=\"switch\"\n                                            :label=\"$tc('ff-export.detail.labelActive')\"\n                                            :helpText=\"$tc('ff-export.detail.helpTextActive')\">\n                                    </sw-field>\n\n                                </div>\n                                <sw-field\n                                        v-model=\"ff_export.interval\"\n                                        type=\"text\"\n                                        required\n                                        :label=\"$tc('ff-export.detail.labelInterval')\"\n                                        placeholder=\"0 * * * *\"\n                                        :helpText=\"$tc('ff-export.detail.helpTextInterval')\">\n                                </sw-field>\n\n                                {% block ff_export_detail_basic_info_download_protection %}\n\n                                    <sw-field\n                                        v-model=\"ff_export.downloadUsername\"\n                                        type=\"text\"\n                                        required\n                                        :label=\"$tc('ff-export.detail.downloadUsername')\"\n                                        :placeholder=\"placeholder(ff_export, 'downloadUsername', $tc('ff-export.detail.downloadUsername'))\">\n                                    </sw-field>\n\n                                    <sw-field\n                                        v-model=\"ff_export.downloadPassword\"\n                                        type=\"password\"\n                                        required\n                                        :label=\"$tc('ff-export.detail.downloadPassword')\"\n                                        :placeholder=\"placeholder(ff_export, 'downloadPassword', $tc('ff-export.detail.downloadPassword'))\">\n                                    </sw-field>\n\n                                {% endblock %}\n\n                                {% block ff_export_detail_basic_info_saleschannel_language %}\n                                    <sw-field\n                                            v-model=\"ff_export.salesChannelId\"\n                                            type=\"select\"\n                                            required\n                                            :options=\"salesChannelIdsList\"\n                                            :label=\"$tc('ff-export.detail.labelSalesChannel')\">\n                                    </sw-field>\n                                    <sw-field\n                                            v-model=\"ff_export.languageId\"\n                                            type=\"select\"\n                                            required\n                                            :options=\"languageIdsList\"\n                                            :label=\"$tc('ff-export.detail.labelLanguage')\">\n                                    </sw-field>\n                                    <sw-entity-multi-select\n                                            v-if=\"baseCategories\"\n                                            v-model=\"baseCategories\"\n                                            required\n                                            entity-name=\"category\"\n                                            :label=\"$tc('ff-export.detail.baseCategoryLabel')\"\n                                            @change=\"onChangeBaseCategory\"\n                                    />\n                                {% endblock %}\n\n                            {% endblock %}\n                        </sw-card-section>\n\n                        {% block ff_export_detail_basic_info_secondary_section %}\n                            <sw-card-section secondary slim v-if=\"!isNew\">\n                                <sw-container columns=\"repeat(auto-fit, minmax(250px, 1fr))\" gap=\"0 30px\">\n                                    <sw-description-list>\n                                        <div class=\"headline\">\n                                            {{ $tc('ff-export.detail.labelDetails') }}\n                                        </div>\n\n                                        {% block ff_export_detail_basic_info_lastgeneration_started %}\n                                            <dt>{{ $tc('ff-export.detail.labelLastGenerationStarted') }}</dt>\n                                            <dd v-if=\"ff_export.lastGenerationStartedAt\">{{ formatDate(ff_export.lastGenerationStartedAt) }}</dd>\n                                            <dd v-else>-</dd>\n                                        {% endblock %}\n\n                                        {% block ff_export_detail_basic_info_lastgeneration_finished %}\n                                            <dt>{{ $tc('ff-export.detail.labelLastGenerationFinished') }}</dt>\n                                            <dd v-if=\"ff_export.lastGenerationFinishedAt\">{{ formatDate(ff_export.lastGenerationFinishedAt) }}</dd>\n                                            <dd v-else>-</dd>\n                                        {% endblock %}\n\n                                        {% block ff_export_detail_basic_info_next_generation_due_at %}\n                                            <dt>{{ $tc('ff-export.detail.labelNextGenerationDueAt') }}</dt>\n                                            <dd v-if=\"ff_export.nextGenerationDueAt\">{{ formatDate(ff_export.nextGenerationDueAt) }}</dd>\n                                            <dd v-else>-</dd>\n                                        {% endblock %}\n\n                                        {% block ff_export_detail_basic_info_status %}\n                                            <dt>{{ $tc('ff-export.detail.status.title') }}</dt>\n                                            <dd>\n                                                <sw-field\n                                                        v-model=\"getDownloadUrl\"\n                                                        type=\"text\"\n                                                        readonly>\n                                                </sw-field>\n                                                <sw-button variant=\"primary\"\n                                                           size=\"small\"\n                                                           v-if=\"status.exists\"\n                                                           :disabled=\"!status.exists\"\n                                                           @click=\"onDownloadExport\">\n                                                    {{ $tc('ff-export.detail.download') }}\n                                                </sw-button>\n                                                <sw-button variant=\"danger\"\n                                                           size=\"small\"\n                                                           v-if=\"!status.exists\"\n                                                           :disabled=\"!status.exists\"\n                                                           @click=\"onDownloadExport\">\n                                                    {{ $tc('ff-export.detail.status.notExists') }}\n                                                </sw-button>\n                                                <sw-button class=\"ff-export-button-generate\"\n                                                           variant=\"primary\"\n                                                           size=\"small\"\n                                                           :disabled=\"isGenerating\"\n                                                           @click=\"onGenerate\">\n                                                    {{ isGenerating?$tc('ff-export.detail.buttonGenerateInProgress'):$tc('ff-export.detail.buttonGenerate') }}\n                                                </sw-button>\n                                            </dd>\n                                        {% endblock %}\n\n                                        {% block ff_export_detail_basic_info_export_id %}\n                                            <dt>{{ $tc('ff-export.detail.labelExportCommand') }}</dt>\n                                            <dd>\n                                                <sw-field\n                                                        v-model=\"command\"\n                                                        type=\"text\"\n                                                        readonly>\n                                                </sw-field>\n                                                <sw-field\n                                                        v-model=\"commandForce\"\n                                                        type=\"switch\"\n                                                        :label=\"$tc('ff-export.detail.labelExportCommandForce')\">\n                                                </sw-field>\n                                            </dd>\n                                        {% endblock %}\n                                    </sw-description-list>\n                                </sw-container>\n                            </sw-card-section>\n                        {% endblock %}\n                    </sw-container>\n                </sw-card>\n\n                <sw-card v-if=\"ff_export\" :title=\"$tc('ff-export.detail.cardTitleConfig')\" :isLoading=\"isLoading\">\n                    <div v-if=\"ff_export.type === 'content'\">\n                        <sw-field\n                            v-model=\"ff_export.config.export_product_categories\"\n                            type=\"switch\"\n                            :label=\"$tc('ff-export.detail.config.export_product_categories')\">\n                        </sw-field>\n                        <sw-field\n                                v-model=\"ff_export.config.export_structure_categories\"\n                                type=\"switch\"\n                                :label=\"$tc('ff-export.detail.config.export_structure_categories')\">\n                        </sw-field>\n                        <sw-field\n                                v-model=\"ff_export.config.export_link_categories\"\n                                type=\"switch\"\n                                :label=\"$tc('ff-export.detail.config.export_link_categories')\">\n                        </sw-field>\n                    </div>\n                    <sw-field\n                            v-model=\"ff_export.config.trigger_import_search_data\"\n                            type=\"switch\"\n                            :label=\"$tc('ff-export.detail.config.trigger_import_search_data')\">\n                    </sw-field>\n                    <sw-field\n                            v-model=\"ff_export.config.trigger_import_suggest_data\"\n                            type=\"switch\"\n                            :label=\"$tc('ff-export.detail.config.trigger_import_suggest_data')\">\n                    </sw-field>\n                </sw-card>\n\n                <sw-card :class=\"[{'ff-mappings--empty':isMappingsEmpty}]\"\n                         v-if=\"!isNew\"\n                         :title=\"$tc('ff-export.detail.cardTitleMappings')\"\n                         :isLoading=\"isLoading\">\n                    <div class=\"ff-mappings\">\n                    {% block ff_export_detail_mapping_info %}\n                        <sw-button class=\"ff-mappings-button-add\"\n                                   variant=\"primary\"\n                                   size=\"small\"\n                                   @click=\"onAddNewMapping\">\n                            {{ $tc('ff-export.detail.buttonMappingAdd') }}\n                        </sw-button>\n\n                        <div class=\"sw-container\" style=\"grid-template-columns: 3fr 3fr 1fr; gap: 0 30px; place-items: stretch;\">\n                            <div>\n                                <div class=\"headline\">{{ $tc('ff-export.detail.columnSource') }}</div>\n                                {% block ff_export_detail_mapping_source_column %}\n                                    <sw-field\n                                            v-for=\"export_mapping in ff_export_mappings\"\n                                            v-model=\"export_mapping.source\"\n                                            type=\"text\"\n                                            :placeholder=\"$tc('ff-export.detail.mappingSourcePlaceholder')\">\n                                    </sw-field>\n                                {% endblock %}\n                            </div>\n                            <div>\n                                <div class=\"headline\">{{ $tc('ff-export.detail.columnTarget') }}</div>\n                                {% block ff_export_detail_mapping_target_column %}\n                                    <sw-field\n                                            v-for=\"export_mapping in ff_export_mappings\"\n                                            v-model=\"export_mapping.target\"\n                                            type=\"text\"\n                                            :placeholder=\"placeholder(ff_export, 'name', $tc('ff-export.detail.placeholderName'))\">\n                                    </sw-field>\n                                {% endblock %}\n                            </div>\n                            <div class=\"ff-mappings-column-actions\">\n                                {% block ff_export_detail_mapping_action_column %}\n                                    <sw-button class=\"ff-mappings-button-delete\"\n                                               v-for=\"export_mapping in ff_export_mappings\"\n                                               variant=\"danger\"\n                                               size=\"small\"\n                                               @click.prevent=\"onDeleteMapping(export_mapping.id)\">\n                                        {{ $tc('ff-export.detail.buttonMappingRemove') }}\n                                    </sw-button>\n                                {% endblock %}\n                            </div>\n                        </div>\n                    {% endblock %}\n                    </div>\n\n                    <sw-empty-state v-if=\"isMappingsEmpty\"\n                                    :title=\"$tc('ff-export.detail.messageMappingsEmptyTitle')\"\n                                    icon=\"default-documentation-file\"\n                                    :subline=\"$tc('ff-export.detail.messageMappingsEmptySubline')\"\n                                    :absolute=\"false\">\n                    </sw-empty-state>\n                </sw-card>\n\n            </sw-card-view>\n        {% endblock %}\n    </sw-page>\n{% endblock %}\n";