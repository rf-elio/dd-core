module.exports = "{% block ff_logging_list_page %}\n    <sw-page class=\"elio-ff-logging-list\">\n        <template #smart-bar-actions>\n            <sw-button\n                    size=\"small\"\n                    variant=\"primary\"\n                    @click=\"loadInitial\"\n            >\n                &nbsp;<sw-icon name=\"small-arrow-360-left\" :small=\"true\"></sw-icon>&nbsp;\n            </sw-button>\n            <sw-button size=\"small\"\n                       variant=\"danger\"\n                       @click=\"openDeleteModal\"\n                       v-if=\"hasLogs\"\n            >\n                &nbsp;<sw-icon name=\"small-trash\" :small=\"true\"></sw-icon>&nbsp;\n            </sw-button>\n        </template>\n\n        <sw-card-view slot=\"content\">\n            <sw-loader v-if=\"isLoading\" size=\"50px\"></sw-loader>\n            {{ selectedLog }}\n            <sw-card v-if=\"hasLogs\">\n                <sw-single-select\n                        :options=\"logs\"\n                        v-model=\"selectedLog\"\n                        size=\"medium\"\n                ></sw-single-select>\n            </sw-card>\n\n            <div class=\"elio-ff-logging-list__content\">\n                <template v-if=\"contents.length\">\n                    <template v-for=\"(content, index) in contents\">\n                        <sw-card :title=\"index + 1\">\n                            <div v-html=\"content\"></div>\n                        </sw-card>\n                    </template>\n                    <div ref=\"pagination\"></div>\n                </template>\n                <template v-else>\n                    <sw-card>{{ $tc('ff-logging.logIsEmpty') }}</sw-card>\n                </template>\n            </div>\n\n            <ff-modal-delete-log\n                    :log-index=\"selectedLog\"\n                    :log-name=\"selectedLogName\"\n                    v-if=\"logs.length && showDeleteModal\"\n                    @ff-close-delete-modal=\"closeDeleteModal\"\n                    @ff-log-deleted=\"onDeleted\"\n            ></ff-modal-delete-log>\n        </sw-card-view>\n    </sw-page>\n{% endblock %}\n";