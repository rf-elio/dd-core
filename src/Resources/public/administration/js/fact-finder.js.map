module.exports = "{% block ff_restrictions_customfilters_page %}\n    <sw-meteor-card>\n        <h1>{{ $tc('ff.restrictions.tabs.customfilters') }}</h1>\n\n        {% block ff_restrictions_customfilters_content %}\n        <div class=\"elio-ff-restrictions-customfilters-list__content\">\n\n            {% block ff_restrictions_customfilters_grid %}\n            <sw-entity-listing\n                    class=\"elio-ff-restrictions-customfilters-list-grid\"\n                    identifier=\"elio-ff-restrictions-customfilters-list\"\n                    :items=\"filtersGroup\"\n                    :columns=\"filtersColumns\"\n                    :repository=\"filtersRepository\"\n                    :isLoading=\"isLoading\"\n\n                    :showSelection=\"false\"\n                    :showSettings=\"true\"\n                    :allowColumnEdit=\"false\"\n                    :fullPage=\"false\"\n                    :compactMode=\"true\"\n\n                    :sortBy=\"sortBy\"\n                    :sortDirection=\"sortDirection\"\n                    @column-sort=\"onSortColumn\"\n                    @page-change=\"onPageChange\"\n                    :disableDataFetching=\"true\"\n                    ref=\"filterList\">\n\n                <template slot=\"column-propertyName\" slot-scope=\"{ item }\">\n                    <router-link :to=\"{ name: 'elio.factfinder.restrictions.customFiltersDetail', params: { id: item.id } }\">\n                        {{ item.translated.propertyName }}\n                    </router-link>\n                </template>\n\n                {% block ff_restrictions_customfilters_grid_columns_actions %}\n                <template slot=\"actions\" slot-scope=\"{ item }\">\n                    {% block ff_restrictions_customfilters_grid_columns_actions_detail %}\n                    <sw-context-menu-item\n                            :routerLink=\"{ name: 'elio.factfinder.restrictions.customFiltersDetail', params: { id: item.id } }\">\n                        {{ $tc('ff.restrictions.customFilters.contextMenuView') }}\n                    </sw-context-menu-item>\n                    {% endblock %}\n\n                    {% block ff_restrictions_customfilters_grid_columns_actions_delete %}\n                        <sw-context-menu-item variant=\"danger\"\n                                              @click=\"onDelete(item.id)\">\n                            {{ $tc('ff.restrictions.customFilters.contextMenuDelete') }}\n                        </sw-context-menu-item>\n                    {% endblock %}\n                </template>\n                {% endblock %}\n\n                {% block ff_restrictions_customfilters_grid_action_modals %}\n                    <template slot=\"action-modals\" slot-scope=\"{ item }\">\n                        <sw-modal v-if=\"showDeleteModal === item.id\"\n                                  variant=\"small\"\n                                  :title=\"$tc('global.default.warning')\"\n                                  @modal-close=\"onCloseDeleteModal\">\n                            <p>\n                                {{ $tc('ff.restrictions.customFilters.textDeleteConfirm', 0, { propertyName: item.translated.propertyName }) }}\n                            </p>\n\n                            <template slot=\"modal-footer\">\n                                <sw-button @click=\"onCloseDeleteModal\" size=\"small\">\n                                    {{ $tc('ff.restrictions.customFilters.buttonCancel') }}\n                                </sw-button>\n\n                                <sw-button @click=\"onConfirmDelete(item.id)\" variant=\"danger\" size=\"small\">\n                                    {{ $tc('ff.restrictions.customFilters.buttonDelete') }}\n                                </sw-button>\n                            </template>\n                        </sw-modal>\n                    </template>\n                {% endblock %}\n\n            </sw-entity-listing>\n            {% endblock %}\n        </div>\n        {% endblock %}\n\n    </sw-meteor-card>\n{% endblock %}";