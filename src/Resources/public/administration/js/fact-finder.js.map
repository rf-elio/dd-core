module.exports = "{% block ff_restrictions_ruler %}\n    <div class=\"elio-ff-restrictions-ruler\">\n        <sw-loader v-if=\"isLoading\"></sw-loader>\n        <sw-field\n                v-model=\"languageId\"\n                type=\"select\"\n                required\n                :options=\"languageIdsList\"\n                :label=\"$tc('ff-export.detail.labelLanguage')\">\n        </sw-field>\n\n        <h1>{{ $tc(rulerHeader) }}</h1>\n\n        <div v-if=\"isInheritable\" class=\"elio-ff-restrictions-ruler-inheritance-block\">\n            <sw-inheritance-switch\n                    class=\"sw-inherit-wrapper__inheritance-icon elio-ff-restrictions-ruler-inheritance\"\n                    :isInherited=\"isInherited\"\n                    @inheritance-restore=\"restoreInheritance\"\n                    @inheritance-remove=\"removeInheritance\">\n            </sw-inheritance-switch>\n            <p>{{ $tc('ff.restrictions.ruler.inheritance') }}</p>\n        </div>\n        <div class=\"ruler\">\n            <div class=\"ruler-tab\">\n                <h3 class=\"ruler-tab-header\">\n                    {{ $tc('ff.restrictions.ruler.tabs.available.header') }}\n                </h3>\n                <div id=\"rulerTabFilters\"\n                     :class=\"['ruler-tab-filter-list', 'ruler-tab-filter-list--main', {'ruler-tab-filter-list--inactive': isInherited}]\"\n                     @drop=\"onDrop\"\n                     ondragover=\"event.preventDefault()\"\n                     data-filter-column=\"all\"\n                >\n                    <div class=\"filter\"\n                         style=\"order: 1;\"\n                         draggable=\"true\"\n                         @dragstart=\"onDragStart\"\n                         v-for=\"filter in allList\"\n                         :data-filter-id=\"filter.id\"\n                    >{{ filter.translated.propertyName }}</div>\n                </div>\n            </div>\n            <div class=\"ruler-tab\">\n                <h3 class=\"ruler-tab-header\">{{ $tc('ff.restrictions.ruler.tabs.allowed.header') }}</h3>\n                <div class=\"ruler-tab-permissions\">\n                    <p class=\"ruler-tab-permissions-header\">{{ $tc('ff.restrictions.ruler.tabs.permissions') }}:</p>\n                    <div class=\"ruler-tab-permission-inputgroup\">\n                        <input type=\"radio\"\n                               id=\"allowAll\"\n                               name=\"allowRule\"\n                               :disabled=\"isInherited\"\n                               :checked=\"allowAllChecked\"\n                               @change=\"onAllowAllClicked\"\n                               value=\"allowAll\">\n                        <label for=\"allowAll\">{{ $tc('ff.restrictions.ruler.tabs.allowed.permissions.allowAll') }}</label>\n                    </div>\n                    <div class=\"ruler-tab-permission-inputgroup\">\n                        <input type=\"radio\"\n                               id=\"allowOnly\"\n                               name=\"allowRule\"\n                               :disabled=\"isInherited\"\n                               :checked=\"!allowAllChecked\"\n                               @change=\"onAllowSelectedClicked\"\n                               value=\"allowOnly\">\n                        <label for=\"allowOnly\">{{ $tc('ff.restrictions.ruler.tabs.allowed.permissions.allowOnlySelected') }}</label>\n                    </div>\n                </div>\n                <div id=\"rulerTabFiltersAllowed\"\n                     :class=\"['ruler-tab-filter-list', {'ruler-tab-filter-list--inactive': isInherited}]\"\n                     @drop=\"onDrop\"\n                     ondragover=\"event.preventDefault()\"\n                     data-filter-column=\"allow\"\n                >\n                    <div class=\"filter\"\n                         style=\"order: 1;\"\n                         draggable=\"true\"\n                         @dragstart=\"onDragStart\"\n                         v-for=\"filter in allowList\"\n                         :data-filter-id=\"filter.id\"\n                    >{{ filter.propertyName }}</div>\n                </div>\n            </div>\n            <div class=\"ruler-tab\">\n                <h3 class=\"ruler-tab-header\">{{ $tc('ff.restrictions.ruler.tabs.blocked.header') }}</h3>\n                <div class=\"ruler-tab-permissions\">\n                    <p class=\"ruler-tab-permissions-header\">{{ $tc('ff.restrictions.ruler.tabs.permissions') }}:</p>\n                    <div class=\"ruler-tab-permission-inputgroup\">\n                        <input type=\"radio\"\n                               id=\"blockAll\"\n                               name=\"blockRule\"\n                               :disabled=\"isInherited\"\n                               :checked=\"blockAllChecked\"\n                               @change=\"onBlockAllClicked\"\n                               value=\"blockAll\">\n                        <label for=\"blockAll\">{{ $tc('ff.restrictions.ruler.tabs.blocked.permissions.blockAll') }}</label>\n                    </div>\n                    <div class=\"ruler-tab-permission-inputgroup\">\n                        <input type=\"radio\"\n                               id=\"blockOnly\"\n                               name=\"blockRule\"\n                               :disabled=\"isInherited\"\n                               :checked=\"!blockAllChecked\"\n                               @change=\"onBlockSelectedClicked\"\n                               value=\"blockOnly\">\n                        <label for=\"blockOnly\">{{ $tc('ff.restrictions.ruler.tabs.blocked.permissions.blockOnlySelected') }}</label>\n                    </div>\n                </div>\n                <div id=\"rulerTabFiltersBlocked\"\n                     :class=\"['ruler-tab-filter-list', {'ruler-tab-filter-list--inactive': isInherited}]\"\n                     @drop=\"onDrop\"\n                     ondragover=\"event.preventDefault()\"\n                     data-filter-column=\"block\"\n                >\n                    <div class=\"filter\"\n                         style=\"order: 1;\"\n                         draggable=\"true\"\n                         @dragstart=\"onDragStart\"\n                         v-for=\"filter in blockList\"\n                         :data-filter-id=\"filter.id\"\n                    >{{ filter.propertyName }}</div>\n                </div>\n            </div>\n        </div>\n\n        {% block sw_category_content_discard_changes_modal %}\n            <sw-discard-changes-modal v-if=\"isDisplayingLeavePageWarning\"\n                                      @keep-editing=\"onLeaveModalClose(nextRoute)\"\n                                      @discard-changes=\"onLeaveModalConfirm(nextRoute)\">\n            </sw-discard-changes-modal>\n        {% endblock %}\n    </div>\n{% endblock %}";