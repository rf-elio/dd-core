module.exports = "<sw-page class=\"elio-extension-config\" hideIcon>\n    <template slot=\"smart-bar-header\">\n        {{ namespace }}\n    </template>\n    <template slot=\"smart-bar-actions\">\n        <sw-button variant=\"primary\" class=\"sw-extension-config__save-action\" @click.prevent=\"onSave\">\n            {{ $tc('global.default.save') }}\n        </sw-button>\n    </template>\n    <template slot=\"language-switch\" v-if=\"isLanguageDivided\">\n        <elio-language-selector\n                :languages=\"languages\"\n                @on-selected=\"onChangeLanguage\" ></elio-language-selector>\n    </template>\n    <sw-card-view slot=\"content\">\n        <sw-system-config :domain=\"domain\"\n                          salesChannelSwitchable\n                          :salesChannelId=\"salesChannelId\"\n                          ref=\"systemConfig\">\n        </sw-system-config>\n    </sw-card-view>\n</sw-page>";