module.exports = "{% block ff_export_list_page %}\n    <sw-page class=\"eli-ff-export-list\">\n        <template #smart-bar-actions>\n            <sw-button\n                    variant=\"primary\"\n                    :router-link=\"{ name: 'elio.factfinder.export.create' }\"\n            >\n                {{ $tc('ff-export.list.buttonCreate') }}\n            </sw-button>\n        </template>\n\n        <template slot=\"content\">\n            <div>\n                {% block ff_export_list_grid %}\n                    <sw-entity-listing\n                            v-if=\"exports\"\n                            class=\"ff-exports-list-grid\"\n                            identifier=\"ff-exports-list\"\n                            :items=\"exports\"\n                            :columns=\"exportColumns\"\n                            :repository=\"exportRepository\"\n                            detailRoute=\"elio.factfinder.export.detail\"\n                            :disableDataFetching=\"true\"\n                            :isLoading=\"isLoading\"\n                            :showSelection=\"true\"\n                            @selection-change=\"updateSelection\"\n                            :allowInlineEdit=\"false\"\n                            @page-change=\"onPageChange\"\n                            :sortBy=\"sortBy\"\n                            :sortDirection=\"sortDirection\"\n                            @column-sort=\"onSortColumn\">\n\n                        {% block ff_export_list_grid_columns_salesChannel %}\n                            <template #column-salesChannelId=\"{ item }\">\n                                {{ item.salesChannel ? item.salesChannel.translated.name : '-' }}\n                            </template>\n                        {% endblock %}\n\n                        {% block ff_export_list_grid_columns_language %}\n                            <template #column-languageId=\"{ item }\">\n                                {{ item.language ? item.language.name : '-' }}\n                            </template>\n                        {% endblock %}\n\n                        {% block ff_export_list_grid_columns_last_generation_time %}\n                            <template #column-lastGenerationFinishedAt=\"{ item }\">\n                                {{ item.lastGenerationFinishedAt ? formatDate(item.lastGenerationFinishedAt) : '-' }}\n                            </template>\n                        {% endblock %}\n\n                        {% block ff_export_list_grid_columns_actions %}\n                            <template slot=\"actions\" slot-scope=\"{ item }\">\n                                {% block ff_export_list_grid_columns_actions_detail %}\n                                    <sw-context-menu-item\n                                            :routerLink=\"{ name: 'elio.factfinder.export.detail', params: { id: item.id } }\">\n                                        {{ $tc('ff-export.list.contextMenuView') }}\n                                    </sw-context-menu-item>\n                                {% endblock %}\n\n                                {% block ff_export_list_grid_columns_actions_delete %}\n                                    <sw-context-menu-item variant=\"danger\"\n                                                          @click=\"onDelete(item.id)\">\n                                        {{ $tc('ff-export.list.contextMenuDelete') }}\n                                    </sw-context-menu-item>\n                                {% endblock %}\n                            </template>\n                        {% endblock %}\n\n                        {% block ff_export_list_grid_action_modals %}\n                            <template slot=\"action-modals\" slot-scope=\"{ item }\">\n                                <sw-modal v-if=\"showDeleteModal === item.id\"\n                                          variant=\"small\"\n                                          :title=\"$tc('global.default.warning')\"\n                                          @modal-close=\"onCloseDeleteModal\">\n                                    <p>\n                                        {{ $tc('ff-export.list.textDeleteConfirm', 0, { name: item.name }) }}\n                                    </p>\n                                    <template slot=\"modal-footer\">\n                                        <sw-button @click=\"onCloseDeleteModal\" size=\"small\">\n                                            {{ $tc('ff-export.list.buttonCancel') }}\n                                        </sw-button>\n                                        <sw-button @click=\"onConfirmDelete(item.id)\" variant=\"danger\" size=\"small\">\n                                            {{ $tc('ff-export.list.buttonDelete') }}\n                                        </sw-button>\n                                    </template>\n                                </sw-modal>\n                            </template>\n                        {% endblock %}\n\n                        <template #pagination>\n                            {% block ff_export_list_grid_pagination %}\n                                <sw-pagination :page=\"page\"\n                                               :limit=\"limit\"\n                                               :total=\"total\"\n                                               :total-visible=\"7\"\n                                               @page-change=\"onPageChange\">\n                                </sw-pagination>\n                            {% endblock %}\n                        </template>\n                    </sw-entity-listing>\n                {% endblock %}\n            </div>\n        </template>\n    </sw-page>\n{% endblock %}";