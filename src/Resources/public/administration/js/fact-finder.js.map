module.exports = "{% block ff_restrictions_customfilters_detail %}\n    <sw-page class=\"sw-property-detail\">\n\n        {% block ff_restrictions_customfilters_detail_smart_bar_header %}\n            <template slot=\"smart-bar-header\">\n                {% block ff_restrictions_customfilters_detail_smart_bar_header_title %}\n                    <h2>{{ placeholder(filter, 'propertyName', $tc('ff.restrictions.filters.detail.textHeadline')) }}</h2>\n                {% endblock %}\n            </template>\n        {% endblock %}\n\n        {% block ff_restrictions_customfilters_detail_smart_bar_actions %}\n            <template slot=\"smart-bar-actions\">\n                {% block ff_restrictions_customfilters_detail_smart_bar_actions_cancel %}\n                    <sw-button class=\"sw-property-detail__back-action\"\n                               :disabled=\"isLoading\"\n                               @click=\"onCancel\">\n                        {{ $tc('ff.restrictions.filters.buttonCancel') }}\n                    </sw-button>\n                {% endblock %}\n\n                {% block ff_restrictions_customfilters_detail_smart_bar_actions_save %}\n                    <sw-button-process\n                            class=\"sw-property-detail__save-action\"\n                            :isLoading=\"isLoading\"\n                            :processSuccess=\"isSaveSuccessful\"\n                            :disabled=\"isLoading\"\n                            variant=\"primary\"\n                            @process-finish=\"saveFinish\"\n                            @click.prevent=\"onSave\">\n                        {{ $tc('ff.restrictions.filters.buttonSave') }}\n                    </sw-button-process>\n                {% endblock %}\n            </template>\n        {% endblock %}\n\n        {% block ff_restrictions_customfilters_detail_language_switch %}\n            <template slot=\"language-switch\">\n                <sw-language-switch @on-change=\"onChangeLanguage\"\n                                    :saveChangesFunction=\"saveOnLanguageChange\"\n                                    :abortChangeFunction=\"abortOnLanguageChange\">\n                </sw-language-switch>\n            </template>\n        {% endblock %}\n\n        {% block ff_restrictions_customfilters_detail_content %}\n            <sw-card-view slot=\"content\">\n                {% block ff_restrictions_customfilters_detail_content_language_info %}\n                    <sw-language-info\n                            :entityDescription=\"placeholder(filter, 'propertyName', $tc('ff.restrictions.filters.detail.textHeadline'))\">\n                    </sw-language-info>\n                {% endblock %}\n\n                <sw-card v-if=\"filter\" :title=\"$tc('ff.restrictions.filters.detail.cardTitleGroupInfo')\" :isLoading=\"isLoading\">\n                    {% block ff_restrictions_customfilters_detail_technical_name %}\n                        <sw-field\n                                v-model=\"filter.technicalName\"\n                                type=\"text\"\n                                required\n                                :label=\"$tc('ff.restrictions.filters.detail.labelTechnicalName')\"\n                                :placeholder=\"placeholder(filter, 'technicalName', $tc('ff.restrictions.filters.placeholderTechnicalName'))\"/>\n                    {% endblock %}\n                    {% block ff_restrictions_customfilters_detail_base_name %}\n                        <sw-field\n                                v-model=\"filter.propertyName\"\n                                type=\"text\"\n                                required\n                                :label=\"$tc('ff.restrictions.filters.detail.labelName')\"\n                                :placeholder=\"placeholder(filter, 'propertyName', $tc('ff.restrictions.filters.placeholderPropertyName'))\"/>\n                    {% endblock %}\n                </sw-card>\n            </sw-card-view>\n        {% endblock %}\n    </sw-page>\n{% endblock %}\n";