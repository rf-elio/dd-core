module.exports = "{% block ff_modal_delete_log %}\n    <sw-modal\n            class=\"ff-modal-delete-log\"\n            variant=\"small\"\n            :title=\"$tc('ff-logging.modal.title')\"\n            @modal-close=\"closeDeleteModal($event)\"\n    >\n        {{ $tc('ff-logging.modal.body', 1, { name: logName }) }}\n        {% block ff_modal_delete_log_footer %}\n            <template slot=\"modal-footer\">\n                <sw-button\n                        size=\"small\"\n                        @click=\"closeDeleteModal($event)\"\n                >\n                    {{ $tc('ff-logging.modal.cancel') }}\n                </sw-button>\n\n                <sw-button\n                        size=\"small\"\n                        variant=\"danger\"\n                        :is-loading=\"isLoading\"\n                        @click=\"deleteLog($event)\"\n                >\n                    {{ $tc('ff-logging.modal.delete') }}\n                </sw-button>\n            </template>\n        {% endblock %}\n    </sw-modal>\n{% endblock %}\n";