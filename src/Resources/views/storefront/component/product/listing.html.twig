{% sw_extends '@Storefront/storefront/component/product/listing.html.twig' %}

{% if cmsPage %}
    {% set slots = [
        cmsPage.firstElementOfType('product-listing').id,
        cmsPage.firstElementOfType('sidebar-filter').id
    ] %}

    {% set params = params|merge({slots: slots|join('|')}) %}
{% endif %}
{% set disableEmptyFilter = false %}

{% block product_listing %}
    {% set elioDataDiscoveryQuery = page.searchTerm %}
    {% set elioDataDiscoveryPage = searchResult.page %}
    {% set elioDataDiscoveryPageSize = searchResult.limit %}

    {% if searchResult.extensions.TrackingResponse is defined %}
        {% set trackingResponse = searchResult.extensions.TrackingResponse %}
        {% set elioDataDiscoveryQuery = trackingResponse.query %}
        {% set elioDataDiscoveryPage = trackingResponse.pageNo %}
        {% set elioDataDiscoveryPageSize = trackingResponse.pageSize %}
    {% endif %}

    {{ parent() }}
{% endblock %}

{# feedback text integration + cms advisor campaign handling #}
{% block element_product_listing_row %}
    {% set showListing = true %}

    {% if showListing %}
        {# feedback text #}
        {% sw_include '@ElioDataDiscovery/storefront/component/elio-data-discovery/campaign/elio-data-discovery-campaign-feedback.html.twig' with {
            label: 'above search result', container: searchResult
        } %}

        {% sw_include '@Storefront/storefront/component/content/listing.html.twig' with {
            listing: topProductsContentGroup
        } %}
        {{ parent() }}

        {# feedback text #}
        {% sw_include '@ElioDataDiscovery/storefront/component/elio-data-discovery/campaign/elio-data-discovery-campaign-feedback.html.twig' with {
            label: 'below search result', container: searchResult
        } %}
    {% endif %}
{% endblock %}



