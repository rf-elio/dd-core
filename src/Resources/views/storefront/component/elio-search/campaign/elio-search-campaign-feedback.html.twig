{% block elio_search_campaign_feedback %}
    {% if container and container.hasExtension('CampaignFeedbackResponseCollection') %}
        {% set campaignFeedbackResponseCollection = container.getExtension('CampaignFeedbackResponseCollection') %}
        {% for feedbackText in campaignFeedbackResponseCollection.getByLabel(label) %}
            <div class="elio-elio-search-campaign-feedback-{{ location }}">
                {% if feedbackText.html %}
                    {{ feedbackText.text|raw }}
                {% else %}
                    {{ feedbackText.text }}
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}
{% endblock %}
