{% if container and container.hasExtension('AdvisorCampaignResponseCollection') %}
    {% set campaign = container.getExtension('AdvisorCampaignResponseCollection').getFirstCampaign() %}

    {% if campaign %}
        {% set options = {
            url: '',
            productsUrl: path('frontend.elio-ff.advisor-products'),
            campaignId: campaign.getId(),
            token: sw_csrf('frontend.elio-ff.advisor-products', {'mode': 'token'}),
            questions: campaign.questionsToArray(),
            filters: container.currentFilters
        } %}

        <div class="advisor"
             data-fact-finder-advisor-campaign
            data-fact-finder-advisor-campaign-options="{{ options|json_encode }}">
            <div data-elio-ff-advisor-questions class=""></div>

            <div data-elio-ff-advisor-products class="products"></div>
        </div>
    {% endif %}
{% endif %}
