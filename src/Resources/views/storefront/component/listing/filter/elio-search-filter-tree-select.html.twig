{% sw_extends '@ElioSearch/storefront/component/listing/filter/elio-search-filter-default-select.html.twig' %}

{% block component_filter_property_select_preview_list_item %}
    {% sw_include '@ElioSearch/storefront/component/listing/filter/elio-search-filter-tree-select-list-item.html.twig' %}
{% endblock %}

{% block component_filter_multi_select_list %}
    {% sw_include '@ElioSearch/storefront/component/listing/filter/elio-search-filter-tree-navigation.html.twig' with {
        navigationTree: elioSearchTree.tree,
        activeResult: elioSearchTree.active,
        activeParent: elioSearchTree.active.path is null
    } only %}
{% endblock %}

{% block component_filter_multi_select %}
    {% set filterItemId = 'filter-' ~ 'elioSearchTree' ~ '-' ~ random() %}
    {{ parent() }}
{% endblock %}
