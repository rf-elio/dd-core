{% sw_extends '@Storefront/storefront/component/listing/filter/filter-multi-select-list-item.html.twig' %}

{% block component_filter_multi_select_list_item %}
    <div class="edd-filter-form-check">
        {% set id = element.id %}
        {% set name = element.translated.name %}

        {% block component_filter_multi_select_list_item_checkbox_input %}
            {% if element.extensions.elio_data_discovery_facet_extension is defined %}
                {% set id = element.extensions.elio_data_discovery_facet_extension.key %}
            {% endif %}
            <input type="checkbox"
                   {% if element.extensions.elio_data_discovery_facet_extension.selected %}checked{% endif %}
                   class="edd-filter-form-check-input filter-multi-select-checkbox"
                   data-label="{{ name }}"
                   value="{{ id }}"
                   id="{{ id }}">
        {% endblock %}

        {% block component_filter_multi_select_list_item_label_element %}
            {% if element.extensions.elio_data_discovery_facet_extension is defined %}
                {% set id = element.extensions.elio_data_discovery_facet_extension.key %}

                {% if config('ElioDataDiscovery.config.listingShowFacetResultCount') %}
                    {% if not element.extensions.elio_data_discovery_facet_extension.selected %}
                        {% set name = name ~ ' (' ~ element.extensions.elio_data_discovery_facet_extension.totalHits ~ ')' %}
                    {% endif %}
                {% endif %}
            {% endif %}
            {{ parent() }}
        {% endblock %}
    </div>
{% endblock %}
