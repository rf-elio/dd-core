{% sw_extends '@Storefront/storefront/component/listing/filter-panel.html.twig' %}

{% block component_filter_panel_item_manufacturer %}
    {{ parent() }}

    {% set elioSearchAggregations = listing.aggregations.get('elio-search-default') %}
    {% for elioSearchAggregation in elioSearchAggregations.aggregations %}
        {% if elioSearchAggregation.extensions.elioSearch is defined %}
            {% set parameterName = elioSearchAggregation.extensions.elio-search.parameterName %}
            {% set style = elioSearchAggregation.extensions.elio-search.style %}

            {% if style == 'DEFAULT' %}
                {% if not elioSearchAggregation.entities is empty %}
                    {% for property in elioSearchAggregation.entities %}
                        {% sw_include '@ElioSearch/storefront/component/listing/filter/elio-search-filter-default-select.html.twig' with {
                            elements: property.options,
                            sidebar: sidebar,
                            name: parameterName,
                            displayName: property.translated.name,
                            displayType: property.displayType,
                            pluginSelector: 'elio-search-filter-property-select',
                            propertyName: property.translated.name,
                            count: property.extensions.elio_search_facet_extension.selectedCount
                        } %}
                    {% endfor %}
                {% endif %}
            {% elseif style == 'SLIDER' %}
                {% if elioSearchAggregation.min > 0 and elioSearchAggregation.max > 0 %}
                    {% sw_include '@ElioSearch/storefront/component/listing/filter/elio-search-filter-range.html.twig' with {
                        price: elioSearchAggregation,
                        sidebar: sidebar,
                        name: elioSearchAggregation.name,
                        minKey: 'min-' ~ elioSearchAggregation.name,
                        maxKey: 'max-' ~ elioSearchAggregation.name,
                        displayName: elioSearchAggregation.name,
                        rangeUnit: elioSearchAggregation.unit
                    } %}
                {% endif %}
            {% elseif style == 'TREE' %}
                {% sw_include '@ElioSearch/storefront/component/listing/filter/elio-search-filter-tree-select.html.twig' with {
                    elements: elioSearchAggregation.extensions.elioSearchTree.tree,
                    sidebar: sidebar,
                    name: parameterName,
                    displayName: parameterName,
                    displayType: 'text',
                    pluginSelector: 'elio-search-filter-tree-select',
                    propertyName: parameterName,
                    elioSearchTree: elioSearchAggregation.extensions.elioSearchTree
                } %}
            {% endif %}
        {% endif %}
    {% endfor %}
{% endblock %}
