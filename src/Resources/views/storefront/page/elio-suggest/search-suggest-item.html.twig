{% block e_layout_search_suggest_result_item %}
    <li class="search-suggest-product js-result">
        {% block layout_search_suggest_result_link %}
            {% if item.hasUrl %} {# meaningless because Suggestion_TYPE_Transformer.php removes results without urls #}
                {{ dump(item) }}
                {% if (item.attributes['routeName'] is defined) and item.attributes['routeParamName'] and item.attributes['routeParamValue'] %}
                    {% set itemUrl = seoUrl(item.attributes['routeName'], {item.attributes['routeParamName']: item.attributes['routeParamValue']}) %}
                {% else %}
                    {% set itemUrl = item.url %}
                {% endif %}
            {% else %}
                {% set itemUrl = path('frontend.search.page')~"?search="~item.name|url_encode %}
            {% endif %}

            <a href="{{ itemUrl }}"
               title="{{ item.name }}"
               class="search-suggest-product-link">

                <div class="row align-items-center no-gutters">
                    {# image #}
                    {% if group.hasImage %}
                        {% block layout_search_suggest_result_image %}
                            <div class="col-auto search-suggest-product-image-container">
                                {% if item.hasImage %}
                                    <img
                                        src="{{ item.imgUrl }}"
                                        sizes="100px"
                                        class="search-suggest-product-image"
                                        alt="{{ item.name }}" />
                                {% else %}
                                    {% sw_icon 'placeholder' style {'size': 'lg'} %}
                                {% endif %}
                            </div>
                        {% endblock %}
                    {% endif %}

                    {# name with highlightes search term #}
                    {% block layout_search_suggest_result_name %}
                        {% set searchMatchPairs = {} %}
                        {% set nameLowerArray = item.name|lower|split('') %}

                        {% for letter in nameLowerArray %}
                            {% set index = loop.index0 %}
                            {% set restOfTheWord = nameLowerArray[index:]|join %}

                            {% if restOfTheWord starts with searchTerm|lower %}
                                {% set match = item.name|split('')|slice(index, searchTerm|length)|join %}

                                {% set searchMatchPairs = searchMatchPairs|merge({(match): "<span class='highlight'>"~match~"</span>"}) %}
                            {% endif %}
                        {% endfor %}

                        <div class="col search-suggest-product-name text-truncate">
                            {{ item.name|replace(searchMatchPairs)|raw }}
                        </div>
                    {% endblock %}
                </div>
            </a>
        {% endblock %}
    </li>
{% endblock %}