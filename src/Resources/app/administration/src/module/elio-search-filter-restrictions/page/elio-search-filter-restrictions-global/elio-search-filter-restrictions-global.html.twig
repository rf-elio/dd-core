{% block elio_search_filter_restrictions_global_page %}
    <sw-meteor-card>
        <div class="elio-search-filter-restrictions-sales-channel-picker">
            <sw-sales-channel-switch :label="$tc('sw-settings.system-config.labelSalesChannelSelect')"
                                     @change-sales-channel-id="onSalesChannelChanged">
            </sw-sales-channel-switch>
        </div>
        <elio-search-filter-restriction-ruler :isCategory="false"
                              :layer="type"
                              rulerHeader="elio-search.restrictions.filter.tabs.global"
                              ref="ruler"></elio-search-filter-restriction-ruler>
    </sw-meteor-card>
{% endblock %}