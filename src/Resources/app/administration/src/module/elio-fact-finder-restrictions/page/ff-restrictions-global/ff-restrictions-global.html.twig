{% block ff_restrictions_global_page %}
    <sw-meteor-card>
        <div class="elio-ff-restrictions-sales-channel-picker">
            <sw-sales-channel-switch :label="$tc('sw-settings.system-config.labelSalesChannelSelect')"
                                     @change-sales-channel-id="onSalesChannelChanged">
            </sw-sales-channel-switch>
        </div>
        <ff-restriction-ruler :isCategory="false"
                              :layer="type"
                              rulerHeader="ff.restrictions.tabs.global"
                              ref="ruler"></ff-restriction-ruler>
    </sw-meteor-card>
{% endblock %}