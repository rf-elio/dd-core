{% block elio_data_discovery_filter_restrictions_index_page %}
    <sw-meteor-page class="elio-data-discovery-filter-restrictions-index" hideIcon>

        {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_tabs %}
            <template slot="page-tabs">
                {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_tabs_global %}
                    <sw-tabs-item :route="{ name: 'elio.data.discovery.filter.restrictions.index.global' }">
                        {{ $tc('elio-data-discovery.restrictions.filter.tabs.global') }}
                    </sw-tabs-item>
                {% endblock %}

                {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_tabs_search %}
                    <sw-tabs-item :route="{ name: 'elio.data.discovery.filter.restrictions.index.search' }">
                        {{ $tc('elio-data-discovery.restrictions.filter.tabs.search') }}
                    </sw-tabs-item>
                {% endblock %}

                {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_tabs_navigation %}
                    <sw-tabs-item :route="{ name: 'elio.data.discovery.filter.restrictions.index.navigation' }">
                        {{ $tc('elio-data-discovery.restrictions.filter.tabs.navigation') }}
                    </sw-tabs-item>
                {% endblock %}

                {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_tabs_customfilters %}
                    <sw-tabs-item :route="{ name: 'elio.data.discovery.filter.restrictions.index.customfilters' }">
                        {{ $tc('elio-data-discovery.restrictions.filter.tabs.customfilters') }}
                    </sw-tabs-item>
                {% endblock %}
            </template>
        {% endblock %}

        {% block elio_data_discovery_filter_restrictions_index_page_smart_bar_actions %}
            <template slot="smart-bar-actions">
                <sw-button-process v-if="!isCustomFiltersTab"
                                   class="sw-category-detail__save-action"
                                   :isLoading="isLoading"
                                   :processSuccess="isSaveSuccessful"
                                   :disabled="isLoading"
                                   variant="primary"
                                   @process-finish="saveFinish"
                                   @click.prevent="onSave">
                    {{ $tc('sw-category.general.buttonSafeCategory') }}
                </sw-button-process>
                <sw-button v-if="isCustomFiltersTab"
                           class="sw-property-list__button-create"
                           :routerLink="{ name: 'elio.data.discovery.filter.restrictions.customFiltersCreate' }"
                           variant="primary">
                    {{ $tc('elio-data-discovery.restrictions.filter.customFilters.buttonAdd') }}
                </sw-button>
            </template>
        {% endblock %}

        {% block elio_data_discovery_filter_restrictions_index_page_body %}
            <template slot="default">
                <router-view ref="routerView"></router-view>
            </template>
        {% endblock %}

    </sw-meteor-page>
{% endblock %}