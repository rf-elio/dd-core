{% block elio_data_discovery_sorting_restrictions_global_page %}
    <sw-meteor-card>
        <div class="elio-data-discovery-sorting-restrictions-sales-channel-picker">
            <sw-sales-channel-switch :label="$tc('sw-settings.system-config.labelSalesChannelSelect')"
                                     @change-sales-channel-id="onSalesChannelChanged">
            </sw-sales-channel-switch>
        </div>
        <elio-data-discovery-sorting-restriction-ruler :isCategory="false"
                              :layer="type"
                              rulerHeader="elio-data-discovery.restrictions.sorting.tabs.global"
                              ref="ruler"></elio-data-discovery-sorting-restriction-ruler>
    </sw-meteor-card>
{% endblock %}