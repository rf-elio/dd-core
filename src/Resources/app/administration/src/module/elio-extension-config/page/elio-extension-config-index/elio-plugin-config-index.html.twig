<sw-meteor-page class="elio-extension-config" hideIcon>
    <div class="sw-extension-my-extensions-listing">
        <sw-loader v-if="isLoading"></sw-loader>

        <div v-if="!isLoading" class="sw-extension-my-extensions-listing__listing-grid">
            <sw-meteor-card v-if="!extensionListPaginated.length && !filterByActiveState" class="sw-extension-my-extensions-listing__empty-state">
                <img :src="'administration/static/img/empty-states/extensions-empty-state.svg' | asset" />
                <h3 v-if="!isAppRoute">{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.themes.titleEmptyState') }}</h3>
                <h3 v-else>{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.apps.titleEmptyState') }}</h3>
                <p v-if="!isAppRoute">{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.themes.textEmptyState') }}</p>
                <p v-else>{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.apps.textEmptyState') }}</p>
            </sw-meteor-card>

            <template v-else>
                <div class="sw-extension-my-extensions-listing__container">

                    <sw-meteor-card v-if="!extensionListPaginated.length && filterByActiveState" class="sw-extension-my-extensions-listing__empty-state">
                        <img :src="'administration/static/img/empty-states/extensions-empty-state.svg' | asset" />
                        <h3 v-if="!isAppRoute">{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.themes.noActivePlugins') }}</h3>
                        <h3 v-else>{{ $tc('sw-extension-store.component.sw-extension-my-extensions-listing.apps.noActivePlugins') }}</h3>
                    </sw-meteor-card>

                    <template v-else>
                        <template v-for="entry in extensionListPaginated">
                            <component
                                    :is="entry ? 'elio-extension-card-base' : 'sw-extension-card-base'"
                                    :key="entry.name"
                                    :extension="entry"
                                    @updateList="updateList">
                            </component>
                        </template>

                        <sw-pagination
                                :total="total"
                                :limit="limit"
                                :page="page"
                                @page-change="changePage"
                        ></sw-pagination>
                    </template>
                </div>
            </template>
        </div>
    </div>
</sw-meteor-page>