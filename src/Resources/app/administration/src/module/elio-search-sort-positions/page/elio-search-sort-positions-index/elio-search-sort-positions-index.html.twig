{% block elio_search_sort_positions_index_page %}
    <sw-meteor-page class="elio-search-sort-positions-index" hideIcon>

        {% block elio_search_sort_positions_index_page_smart_bar_tabs %}
            <template slot="page-tabs">
                {% block elio_search_sort_positions_index_page_smart_bar_tabs_global %}
                    <sw-tabs-item :route="{ name: 'elio.search.sort.positions.index.global' }">
                        {{ $tc('elio-search.sort-positions.tabs.global') }}
                    </sw-tabs-item>
                {% endblock %}
            </template>
        {% endblock %}

        {% block elio_search_sort_positions_index_page_smart_bar_actions %}
            <template slot="smart-bar-actions">
                <sw-button-process v-if="!isCustomFiltersTab"
                                   class="sw-category-detail__save-action"
                                   :isLoading="isLoading"
                                   :processSuccess="isSaveSuccessful"
                                   :disabled="isLoading"
                                   variant="primary"
                                   @process-finish="saveFinish"
                                   @click.prevent="onSave">
                    {{ $tc('sw-category.general.buttonSafeCategory') }}
                </sw-button-process>
                <sw-button v-if="isCustomFiltersTab"
                           class="sw-property-list__button-create"
                           :routerLink="{ name: 'elio.search.sort.positions.customFiltersCreate' }"
                           variant="primary">
                    {{ $tc('sw-property.list.buttonAddProperty') }}
                </sw-button>
            </template>
        {% endblock %}

        {% block elio_search_sort_positions_index_page_body %}
            <template slot="default">
                <router-view ref="routerView"></router-view>
            </template>
        {% endblock %}

    </sw-meteor-page>
{% endblock %}