{% block sw_category_view_tabs_seo %}
    {% parent %}
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.filter.ruler', params: { id: $route.params.id } }"
            :title="$tc('elio-search.restrictions.filter.tabs.category')">
        {{ $tc('elio-search.restrictions.filter.tabs.category') }}
    </sw-tabs-item>
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.sorting.ruler', params: { id: $route.params.id } }"
            :title="$tc('elio-search.restrictions.sorting.tabs.category')">
        {{ $tc('elio-search.restrictions.sorting.tabs.category') }}
    </sw-tabs-item>
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.positions.ruler', params: { id: $route.params.id } }"
            :title="$tc('elio-search.sort-positions.tabs.category')">
        {{ $tc('elio-search.sort-positions.tabs.category') }}
    </sw-tabs-item>
{% endblock %}

{% block sw_category_view_content %}
    <router-view :isLoading="isLoading" ref="routerView"></router-view>
{% endblock %}