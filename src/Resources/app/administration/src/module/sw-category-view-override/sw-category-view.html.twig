{% block sw_category_view_tabs_seo %}
    {% parent %}
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.filter.ruler', params: { id: $route.params.id } }"
            :title="$tc('elio-data-discovery.restrictions.filter.title')">
        {{ $tc('elio-data-discovery.restrictions.filter.title') }}
    </sw-tabs-item>
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.sorting.ruler', params: { id: $route.params.id } }"
            :title="$tc('elio-data-discovery.restrictions.sorting.title')">
        {{ $tc('elio-data-discovery.restrictions.sorting.title') }}
    </sw-tabs-item>
    <sw-tabs-item
            v-show="isPage"
            :route="{ name: 'sw.category.detail.positions.table', params: { id: $route.params.id } }"
            :title="$tc('elio-data-discovery.sort-positions.title')">
        {{ $tc('elio-data-discovery.sort-positions.title') }}
    </sw-tabs-item>
{% endblock %}

{% block sw_category_view_content %}
    <router-view v-slot="{ Component }">
        <component :isLoading="isLoading" :is="Component" ref="routerView"></component>
    </router-view>
{% endblock %}