{% block elio_search_restrictions_category_page %}
    <div class="sw-category-detail-base">
        <div class="elio-search-restrictions-sales-channel-picker elio-search-restrictions-sales-channel-picker--category">
            <sw-sales-channel-switch :label="$tc('sw-settings.system-config.labelSalesChannelSelect')"
                                     @change-sales-channel-id="onSalesChannelChanged">
            </sw-sales-channel-switch>
        </div>

        <sw-card :title="$tc('elio-search.restrictions.tabs.global')"
                 :isLoading="isLoading">
            <elio-search-restriction-ruler :isCategory="true"
                                  :categoryId="category.id"
                                  ref="ruler"></elio-search-restriction-ruler>
        </sw-card>
    </div>
{% endblock %}