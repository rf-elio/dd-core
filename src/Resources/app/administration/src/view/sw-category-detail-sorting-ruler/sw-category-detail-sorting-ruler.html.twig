{% block elio_data_discovery_restrictions_category_page %}
    <div class="sw-category-detail-base">
        <div class="elio-data-discovery-restrictions-sales-channel-picker elio-data-discovery-restrictions-sales-channel-picker--category">
            <sw-sales-channel-switch :label="$tc('sw-settings.system-config.labelSalesChannelSelect')"
                                     @change-sales-channel-id="onSalesChannelChanged">
            </sw-sales-channel-switch>
        </div>

        <sw-card :title="$tc('elio-data-discovery.restrictions.sorting.tabs.global')"
                 :isLoading="isLoading">
            <elio-data-discovery-sorting-restriction-ruler :isCategory="true"
                                  :categoryId="category.id"
                                  :layer="type"
                                  ref="ruler"></elio-data-discovery-sorting-restriction-ruler>
        </sw-card>
    </div>
{% endblock %}