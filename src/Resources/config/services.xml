<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Elio\FactFinder\Service\Export\Exporter" public="true">
            <argument type="service" id="Shopware\Core\Content\ProductStream\Service\ProductStreamBuilder"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Shopware\Core\System\SalesChannel\Context\SalesChannelContextService"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="string">%product_export.read_buffer_size%</argument>
            <argument type="service" id="Shopware\Core\Content\ProductExport\Service\ProductExportFileHandler"/>
            <argument type="service" id="shopware.filesystem.private"/>
            <argument type="service" id="router" />
            <argument type="service" id="currency.repository"/>
            <argument type="service" id="rule.repository"/>
        </service>

        <service id="Elio\FactFinder\Service\Export\ExportManager" public="true">
            <argument type="service" id="product_export.repository"/>
            <argument type="service" id="sales_channel_domain.repository"/>
            <argument type="service" id="product_stream.repository"/>
            <argument type="service" id="sales_channel.repository"/>
            <argument type="service" id="Elio\FactFinder\Service\Export\Exporter"/>
            <argument type="service" id="Shopware\Core\Content\ProductExport\Service\ProductExportValidator"/>
        </service>

        <service id="Elio\FactFinder\Twig\TwigProductUpdaterFunctionExtension" public="true">
            <argument type="service" id="router" />
            <argument type="service" id="currency.repository"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Elio\FactFinder\Service\FactFinderConfiguration" public="true">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService" />
        </service>

        <service id="Elio\FactFinder\Components\ElioFactFinderService" public="true">
            <argument type="service" id="Elio\FactFinder\Service\FactFinderConfiguration" />
            <argument type="service" id="Elio\FactFinder\Components\Helper\FactFinderHelper"/>
            <argument type="service" id="product_manufacturer.repository"/>
            <argument type="service" id="property_group_option.repository"/>
        </service>

        <service id="Elio\FactFinder\Components\Search\FactFinderSuggestRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Suggest\ProductSuggestRoute">
            <argument type="service" id="Shopware\Core\Content\Product\SearchKeyword\ProductSearchBuilderInterface"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Elio\FactFinder\Components\ElioFactFinderService"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Elio\FactFinder\Components\Search\FactFinderSuggestRoute.inner"/>
            <argument type="service" id="sales_channel.category.repository"/>
            <argument type="service" id="product_manufacturer.repository"/>
        </service>

        <service id="Elio\FactFinder\Components\Search\FactFinderSearchRoute"
                 decorates="Shopware\Core\Content\Product\SalesChannel\Search\ProductSearchRoute">
            <argument type="service" id="Shopware\Core\Content\Product\SearchKeyword\ProductSearchBuilderInterface"/>
            <argument type="service" id="event_dispatcher"/>
            <argument type="service" id="Elio\FactFinder\Components\ElioFactFinderService"/>
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="Elio\FactFinder\Components\Search\FactFinderSearchRoute.inner"/>
            <argument type="service" id="product_manufacturer.repository"/>
            <argument type="service" id="sales_channel.category.repository"/>
            <argument type="service" id="property_group_option.repository"/>
            <argument type="service" id="Elio\FactFinder\Components\Helper\FactFinderHelper"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="Shopware\Core\Content\Product\SearchKeyword\ProductSearchTermInterpreter"/>
        </service>

        <service id="Elio\FactFinder\Storefront\Controller\AfterSearchNavigationController" public="true">
            <argument type="service" id="Elio\FactFinder\Components\ElioFactFinderService"/>
            <argument type="service" id="Elio\FactFinder\Components\Helper\FactFinderHelper"/>
        </service>

        <service id="Elio\FactFinder\Components\Helper\FactFinderHelper" public="true">
            <argument type="service" id="sales_channel.product.repository"/>
        </service>

        <service id="Elio\FactFinder\Command\ExportInstallCommand">
            <argument type="service" id="Elio\FactFinder\Service\Export\ExportManager"/>
            <tag name="console.command"/>
        </service>

        <service id="Elio\FactFinder\Command\ExportGenerateCommand">
            <argument type="service" id="Elio\FactFinder\Service\Export\ExportManager"/>
            <tag name="console.command"/>
        </service>

    </services>
</container>
